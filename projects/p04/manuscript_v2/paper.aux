\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Antarctic sea ice extent baseline (NSIDC Sea Ice Index, 1979--2026).} \textbf  {a}, Annual mean extent with Pettitt change point at 2016 ($p = 0.004$). Blue/red shading indicates pre/post-shift mean levels. \textbf  {b}, Seasonal mean extent (DJF, MAM, JJA, SON). Summer (DJF) shows the largest post-2016 decline ($-16.8$\%). \textbf  {c}, Monthly extent with 12-month running mean. \textbf  {d}, Year-to-year change, showing the abrupt shift to persistent negative anomalies after 2016.}}{5}{}\protected@file@percent }
\newlabel{fig:baseline}{{1}{5}{}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {ERA5 significant wave height trends in the Southern Ocean (1979--2024).} \textbf  {a}, Spatial map of SWH percentage change (post-2016 minus pre-2016). Black contours enclose regions where the change is significant ($p < 0.05$, two-sample $t$-test). Widespread increases are concentrated in the ACC belt. \textbf  {b}, Regional annual SWH anomaly time series for four latitude bands. \textbf  {c}, Near-MIZ zone (55--65$^\circ $S) Pettitt change point at 1993 ($p = 0.055$). \textbf  {d}, SWH anomaly versus sea ice extent anomaly ($r = 0.136$). \textbf  {e}, Mean wave period change (post-2016 minus pre-2016).}}{6}{}\protected@file@percent }
\newlabel{fig:swh}{{2}{6}{}{figure.2}{}}
