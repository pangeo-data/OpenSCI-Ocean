\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Granger causality tests for the wave-ice feedback chain. Optimal lag selected by AIC from 1--6 months. $p_{\mathrm  {Bonf}}$ is the Bonferroni-corrected $p$-value for 6 simultaneous tests. Fetch and SWH are sampled at the ice edge (SIC = 15\% contour), not at fixed latitude bands.}}{7}{}\protected@file@percent }
\newlabel{tab:granger}{{1}{7}{}{table.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}Ice shelf buffer changes}{7}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Ice-edge-based fetch proxy and SWH at the ice edge (1979--2024).} \textbf  {a}, Zonal-mean fetch proxy (distance from 40$^\circ $S to ice edge) annual anomaly. Change point at 2016 ($p = 0.009$). \textbf  {b}, SWH sampled at the ice edge. No significant change point ($p = 0.52$). \textbf  {c}, Scatter plot of fetch anomaly versus SWH at the ice edge ($r = -0.19$, $p = 0.20$): fetch does not predict SWH. \textbf  {d}, Ice-edge latitude anomaly with change point at 2016. \textbf  {e}, Granger causality $F$-statistics. Green = significant ($p < 0.05$); orange = marginal; red = not significant. \textbf  {f}, Seasonal cycle of fetch and SWH at the ice edge.}}{8}{}\protected@file@percent }
\newlabel{fig:fetch}{{3}{8}{}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Seasonal dependence and mean wave period evidence for swell attenuation.} \textbf  {a}, SIC$\to $SWH Granger $F$-statistic by season. Only JJA (winter) is significant ($F = 5.10$, $p = 0.007$). \textbf  {b}, Mean wave period (MWP) anomaly at the ice edge. No significant change at 2016. \textbf  {c}, SIC anomaly versus MWP anomaly ($r = +0.24$, $p < 0.001$): positive correlation consistent with sea ice acting as a low-pass filter. \textbf  {d}, MWP seasonal cycle at the ice edge, pre-2016 versus post-2016.}}{9}{}\protected@file@percent }
\newlabel{fig:seasonal}{{4}{9}{}{figure.4}{}}
