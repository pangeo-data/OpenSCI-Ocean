\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Competing wave-ice feedback mechanisms and study domain.} \textbf  {a}, Conceptual diagram of the two hypothesized pathways by which sea ice loss could amplify wave height at the ice edge. Hypothesis A (red, dashed) invokes fetch lengthening: less ice exposes more open water for local wave generation. Hypothesis B (blue, solid) invokes swell-attenuation reduction: less ice shortens the path over which remotely generated swell is attenuated. Green arrows indicate statistically supported Granger-causal links; red dashed arrow indicates the failing link. Granger $p$-values shown. \textbf  {b}, Southern Ocean study domain in south-polar stereographic projection. Light blue band: marginal ice zone (55--65$^\circ $S). Blue dashed circle: mean ice edge ($\sim $65$^\circ $S). Red triangles: five major ice shelves examined for buffer loss. Red arrows: poleward swell propagation. Purple arrows: circumpolar westerlies.}}{5}{}\protected@file@percent }
\newlabel{fig:concept}{{1}{5}{}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Spatial patterns of sea ice and wave height change (post-2016 minus pre-2016).} \textbf  {a}, Sea ice concentration change. Blue dashed contour: pre-2016 ice edge (SIC = 0.15); red solid contour: post-2016 ice edge. Sea ice loss is widespread, with the largest reductions in the Bellingshausen, Amundsen, and Weddell sectors. \textbf  {b}, Significant wave height change. Increases are concentrated in the ACC belt and near the retreated ice edge. Gray dashed contour: pre-2016 ice edge for reference. \textbf  {c}, Pre-2016 mean SIC (shading) with pre-2016 (blue dashed) and post-2016 (red solid) ice edge contours overlaid. Red triangles mark the five ice shelves. The poleward retreat of the ice edge is evident across most sectors. All panels use south-polar stereographic projection with Natural Earth coastlines.}}{6}{}\protected@file@percent }
\newlabel{fig:spatial}{{2}{6}{}{figure.2}{}}
\def\@LN@column{1}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Wave height trends are wind-driven, not fetch-driven}{6}{}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}The feedback chain partially closes through swell attenuation, not fetch}{6}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Antarctic sea ice extent time series (NSIDC Sea Ice Index, 1979--2026).} \textbf  {a}, Annual mean extent with Pettitt change point at 2016 ($p = 0.004$). Blue/red shading indicates pre/post-shift mean levels. \textbf  {b}, Seasonal mean extent (DJF, MAM, JJA, SON). Summer (DJF) shows the largest post-2016 decline ($-16.8$\%). \textbf  {c}, Monthly extent with 12-month running mean. \textbf  {d}, Year-to-year change, showing the abrupt shift to persistent negative anomalies after 2016.}}{7}{}\protected@file@percent }
\newlabel{fig:baseline}{{3}{7}{}{figure.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Granger causality tests for the wave-ice feedback chain. Optimal lag selected by AIC from 1--6 months. $p_{\mathrm  {Bonf}}$ is the Bonferroni-corrected $p$-value for 6 simultaneous tests. Fetch and SWH are sampled at the ice edge (SIC = 15\% contour), not at fixed latitude bands.}}{7}{}\protected@file@percent }
\newlabel{tab:granger}{{1}{7}{}{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {ERA5 significant wave height trends in the Southern Ocean (1979--2024).} \textbf  {a}, Spatial map of SWH percentage change (post-2016 minus pre-2016). Black contours enclose regions where the change is significant ($p < 0.05$, two-sample $t$-test). Widespread increases are concentrated in the ACC belt. \textbf  {b}, Regional annual SWH anomaly time series for four latitude bands. \textbf  {c}, Near-MIZ zone (55--65$^\circ $S) Pettitt change point at 1993 ($p = 0.055$). \textbf  {d}, SWH anomaly versus sea ice extent anomaly ($r = 0.136$). \textbf  {e}, Mean wave period change (post-2016 minus pre-2016).}}{8}{}\protected@file@percent }
\newlabel{fig:swh}{{4}{8}{}{figure.4}{}}
